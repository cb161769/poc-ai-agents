# Imagen dedicada a correr los tests (y, si hace falta, run_poc_loop.sh/
# scripts/smoke_test.sh) DENTRO de un contenedor -- evita depender de que el
# host tenga python3/jq/git/cypher-shell resueltos correctamente en el PATH
# (en Windows, python3 puede resolver al stub de Microsoft Store en vez del
# interprete real; este Dockerfile no depende de eso en absoluto).
#
# Build:  docker build -f Dockerfile.testrunner -t poc-ai-agents-testrunner .
# Tests:  docker run --rm -v "$(pwd):/repo" -w /repo poc-ai-agents-testrunner \
#           python3 -m pytest tests/ -v
FROM python:3.10-slim

WORKDIR /repo

RUN apt-get update \
    && apt-get install -y --no-install-recommends git jq curl openjdk-21-jre-headless docker.io \
    && rm -rf /var/lib/apt/lists/*
# docker.io: el CLI del testing-agent real (scripts/run_module_tests.sh)
# necesita "docker" para levantar el contenedor throwaway con el
# runtime real (Playwright/Maven/Go/etc). Docker-outside-of-Docker: en
# runtime hay que montar el socket real del host (-v
# /var/run/docker.sock:/var/run/docker.sock) para que este CLI hable con el
# daemon real -- ver HOST_TARGET_REPO_DIR en orchestration.py::run_tests()
# para el problema de paths que esto trae (el daemon del host no puede
# montar un path que solo existe DENTRO de este contenedor).

# cypher-shell: distribuido por Neo4j como paquete standalone, no via apt.
RUN curl -fsSL -o /tmp/cypher-shell.deb \
      "https://dist.neo4j.org/cypher-shell/cypher-shell_5.22.0_all.deb" \
    && apt-get update \
    && apt-get install -y --no-install-recommends /tmp/cypher-shell.deb \
    && rm -f /tmp/cypher-shell.deb \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt pytest-timeout uv

# uvx (via el paquete uv) -- coding_agent.py/judge_agent.py/chat.py lo
# invocan para levantar los MCP reales (mcp-neo4j-cypher, mcp-server-qdrant)
# como subprocesos. Sin esto, esas conexiones fallan en silencio (se
# degradan a "MCP no disponible") y el agente pierde acceso al grafo/RAG.

# El codigo se monta en runtime (-v "$(pwd):/repo"), no se copia acá -- así
# corre siempre contra el estado real del repo sin tener que reconstruir la
# imagen en cada cambio.
