# Copia este archivo a .env y rellena tus credenciales reales.
# .env nunca se versiona (ver .gitignore).

# --- Jira Cloud ---
JIRA_URL=https://tuempresa.atlassian.net
JIRA_EMAIL=tu-email@tuempresa.com
JIRA_API_TOKEN=pega-aqui-tu-api-token
JIRA_TICKET_KEY=JIRA-404
JIRA_PROJECT_KEY=JIRA
# Nombre exacto de la transicion de workflow a la que mover el ticket cuando
# el firewall aprueba y se le asigna a un agente (ajustalo a tu workflow real)
JIRA_IN_PROGRESS_STATUS=In Progress
# Como identificas a Rovo como autor de comentarios en tu instancia (para que
# jira_client.py sepa cual comentario es la descripcion de un adjunto/video)
ROVO_AUTHOR_NAME_MATCH=rovo

# --- Azure DevOps ---
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/tuorg
AZURE_DEVOPS_ORG=tuorg
AZURE_DEVOPS_PAT=pega-aqui-tu-pat

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=test_password_local

# --- SonarQube ---
SONAR_URL=http://localhost:9000
SONAR_TOKEN=pega-aqui-el-token-impreso-por-bootstrap_sonar.sh
SONAR_NEW_ADMIN_PASSWORD=LocalPoc_Admin_2026!

# --- Qdrant ---
QDRANT_URL=http://localhost:6333

# --- Cache local ---
CACHE_DIR=./cache
CACHE_TTL_SECONDS=300

# --- Firewall ---
FIREWALL_URL=http://localhost:8080

# --- GitHub Copilot coding agent (opcional) ---
# Si se define, run_poc_loop.sh crea un Issue en este repo y lo asigna al
# coding agent en vez de solo pedir una sugerencia local con gh copilot suggest.
# Requiere Copilot coding agent habilitado en el repo (plan Business/Enterprise).
GITHUB_REPO=tuorg/tu-repo
GITHUB_COPILOT_ASSIGNEE=copilot-swe-agent

# --- Agente juez (opcional pero recomendado) ---
# Segunda opinion independiente (no gh copilot) que revisa la decision del
# firewall + el cambio real + la corrida completa, con poder de bloqueo.
# Backend preferido: Anthropic. Sin ANTHROPIC_API_KEY, cae al Ollama local del
# docker-compose (servicio "ollama") si esta levantado. Sin ninguno de los
# dos, el juez se omite silenciosamente.
ANTHROPIC_API_KEY=sk-ant-pega-aqui-tu-key
ANTHROPIC_MODEL=claude-sonnet-5
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
# Nombre exacto de la transicion de workflow a la que mover el ticket si el
# juez marca la corrida como FLAGGED (ajustalo a tu workflow real)
JIRA_BLOCKED_STATUS=Blocked
