# Copia este archivo a .env y rellena tus credenciales reales.
# .env nunca se versiona (ver .gitignore).

# --- Jira Cloud ---
JIRA_URL=https://tuempresa.atlassian.net
JIRA_EMAIL=tu-email@tuempresa.com
JIRA_API_TOKEN=pega-aqui-tu-api-token
JIRA_TICKET_KEY=JIRA-404
JIRA_PROJECT_KEY=JIRA
# Componentes reales que el pipeline reconoce como repository_origen: primero
# se busca en el campo nativo Components del ticket, con fallback a labels.
# Esto es solo el FALLBACK de esta lista: run_poc_loop.sh/orchestration.py la
# derivan automaticamente de los nombres de nodo reales en Neo4j al arrancar
# cada corrida — esto solo se usa si Neo4j no esta disponible todavia.
JIRA_KNOWN_COMPONENTS=AuthService,Frontend,DataWorker
# Nombre exacto de la transicion de workflow a la que mover el ticket cuando
# el firewall aprueba y se le asigna a un agente (ajustalo a tu workflow real
# -- para confirmar los nombres exactos de TU proyecto: GET
# /rest/api/3/issue/{key}/transitions sobre un ticket real, o con Rovo,
# getTransitionsForJiraIssue. Muchos workflows Kanban simples -- como el que
# trae Jira por default -- no tienen una columna "Blocked" propia; en ese
# caso usa el mismo valor que JIRA_REVIEW_STATUS para JIRA_BLOCKED_STATUS,
# asi un veredicto FLAGGED igual queda visible para revision humana.)
JIRA_IN_PROGRESS_STATUS="In Progress"
# Usada solo por --epic (run_poc_loop.sh --epic EPIC-123 / orchestration.py
# --epic EPIC-123) para encontrar los hijos de una epica. El default sirve
# para proyectos "team-managed" (el campo nativo "parent"). Si tu proyecto
# es "company-managed" y todavia usa el campo custom "Epic Link", cambiala
# por algo como: JIRA_EPIC_LINK_JQL="cf[10014] = \"{epic_key}\""
# (el numero de campo varia por instancia de Jira).
JIRA_EPIC_LINK_JQL="parent = \"{epic_key}\""
# ID del custom field de Sprint en tu instancia de Jira -- varia por
# instancia (customfield_10020 es el default mas comun en Jira Cloud, pero
# no esta garantizado). Se usa solo como metadata informativa (que sprint
# tenia una historia cuando el pipeline la proceso) -- NUNCA filtra ni
# bloquea que historias se procesan. No se valido contra ninguna instancia
# real -- confirma el ID correcto en Jira > Project Settings > Fields, o
# inspeccionando la respuesta cruda de GET /rest/api/3/issue/{key} si no
# estas seguro.
JIRA_SPRINT_FIELD_ID=customfield_10020
# Como identificas a Rovo como autor de comentarios en tu instancia (para que
# jira_client.py sepa cual comentario es la descripcion de un adjunto/video)
ROVO_AUTHOR_NAME_MATCH=rovo

# --- Azure DevOps ---
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/tuorg
AZURE_DEVOPS_ORG=tuorg
AZURE_DEVOPS_PAT=pega-aqui-tu-pat

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=test_password_local

# --- SonarQube ---
SONAR_URL=http://localhost:9000
SONAR_TOKEN=pega-aqui-el-token-impreso-por-bootstrap_sonar.sh
SONAR_NEW_ADMIN_PASSWORD=LocalPoc_Admin_2026!

# --- Qdrant ---
QDRANT_URL=http://localhost:6333

# --- Cache local ---
# Dejar vacio: cache_utils.py ancla el default al directorio del propio
# modulo (repo/cache), no al cwd del proceso que lo importa. Un valor
# relativo aca (ej. "./cache") se resuelve contra el cwd de quien corra el
# pipeline -- dentro de Docker-outside-of-Docker eso es /target-repo, no
# este repo, y termina commiteando cache/*.json en el repo objetivo real
# (bug real confirmado: paso en un PR real de Azure DevOps).
CACHE_DIR=
CACHE_TTL_SECONDS=300

# --- Firewall ---
FIREWALL_URL=http://localhost:8080
# Opcional pero recomendado: si la seteas, /evaluate exige el header
# X-Firewall-Key con este mismo valor (401 si falta o no matchea). Sin esto,
# cualquiera que llegue a FIREWALL_URL puede pegarle al firewall directo, sin
# pasar por Jira/el pipeline. Sin setear, el firewall queda abierto (con un
# aviso al arrancar) para no romper el demo local de quien no la configuro.
FIREWALL_API_KEY=

# --- GitHub Copilot coding agent (opcional) ---
# Si se define, run_poc_loop.sh crea un Issue en este repo y lo asigna al
# coding agent en vez de solo pedir una sugerencia local con gh copilot suggest.
# Requiere Copilot coding agent habilitado en el repo (plan Business/Enterprise).
GITHUB_REPO=tuorg/tu-repo
GITHUB_COPILOT_ASSIGNEE=copilot-swe-agent

# --- Agente juez (opcional pero recomendado) ---
# Segunda opinion independiente (no gh copilot) que revisa la decision del
# firewall + el cambio real + la corrida completa, con poder de bloqueo.
# Backend preferido: Anthropic. Sin ANTHROPIC_API_KEY, cae al Ollama local del
# docker-compose (servicio "ollama") si esta levantado. Sin ninguno de los
# dos, el juez se omite silenciosamente.
ANTHROPIC_API_KEY=sk-ant-pega-aqui-tu-key
ANTHROPIC_MODEL=claude-sonnet-5
# 0.0 = deterministico -- mismo criterio que OLLAMA_TEMPERATURE (ver abajo).
ANTHROPIC_TEMPERATURE=0.0
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
# Cuanto esperar una respuesta de Ollama antes de darla por fallida y probar
# el siguiente backend -- con inferencia por CPU y prompts grandes (coding
# agent, juez) puede tardar varios minutos; subilo si tu hardware es lento,
# bajalo si tenes GPU y preferis fallar rapido.
OLLAMA_TIMEOUT_SECONDS=300
# 0.0 = deterministico. El default de Ollama (~0.7-0.8) es para charla
# natural -- coding_agent.py/judge_agent.py esperan JSON estricto en la
# respuesta final, y mas temperatura es mas chance de narrar en texto libre
# (o inventar hechos) en vez de devolver el esquema pedido o usar las tools
# reales para verificar antes de responder.
OLLAMA_TEMPERATURE=0.0
# Modelo Ollama especifico por agente (opcional) -- si no se setean, cada
# uno cae al OLLAMA_MODEL generico de arriba. Sirve para usar un modelo mas
# fuerte en codigo (coding agent) y uno mas liviano/rapido para el juez
# (solo evalua texto+tools, no escribe codigo). Si estas validando el
# pipeline solo con Ollama (sin credito de Anthropic todavia) y ves
# respuestas JSON vacias/invalidas seguido, probar un modelo mas entrenado
# en tool-calling/JSON estricto que el llama3.1 generico -- por ejemplo
# qwen2.5-coder:7b (`ollama pull qwen2.5-coder:7b`) -- suele ayudar mas que
# cualquier ajuste de prompt.
# Acepta una lista coma-separada de candidatos (orden = prioridad):
# coding_agent.py/judge_agent.py cambian UNA vez por corrida al siguiente
# candidato realmente descargado si el activo alucina (JSON invalido tras
# su reintento de correccion) -- con un solo valor aca ese mecanismo nunca
# tiene a donde cambiar y toda alucinacion termina en "blocked" de una.
# qwen3 (`ollama pull qwen3:8b`) es el modelo que los propios docs de Ollama
# usan como ejemplo principal de tool-calling y de "thinking" -- mejor punto
# de partida real para el loop de investigacion con tools que un modelo
# generico o uno afinado solo para autocompletar codigo.
CODING_AGENT_OLLAMA_MODEL=
JUDGE_OLLAMA_MODEL=
# epic_planner.py ordena las historias de una epica por dependencia real
# (via el grafo Neo4j) SOLO cuando el modelo responde bien -- sin setear
# esto, cae al OLLAMA_MODEL generico (llama3.1 por default), que en la
# practica alucina seguido y degrada siempre al orden mecanico (el orden
# en que Jira devuelve los hijos). Gap real confirmado: una epica intento
# "agregar un componente a un framework" antes que la historia que
# montaba ese framework, porque el ordenamiento real nunca llegaba a
# correr con exito.
EPIC_PLANNER_OLLAMA_MODEL=
# Activa el modo "thinking" de Ollama (docs.ollama.com/capabilities/thinking)
# para los modelos que lo soportan (detectado por nombre: qwen3, gpt-oss,
# deepseek-r1, deepseek-v3) -- separado de content/tool_calls en la
# respuesta, no rompe el parseo existente.
OLLAMA_THINKING_ENABLED=true
# Ventana de contexto de ENTRADA para Ollama (num_ctx) -- default del modelo
# suele ser 2048-4096, chico para los prompts largos de este pipeline (grafo
# + Sonar + el esquema JSON pedido al final). Si segui viendo JSON
# vacio/invalido con Ollama, subi esto antes que nada.
OLLAMA_NUM_CTX=8192

# --- Coding agent local real (Camino B1, opcional) ---
# coding_agent.py usa el MISMO backend de arriba (Anthropic/Ollama). Si no
# hay ANTHROPIC_API_KEY ni Ollama alcanzable, Camino B cae a gh copilot
# suggest (B2) automaticamente -- esto no requiere configuracion aparte.
# Cuantos turnos de herramientas puede usar antes de rendirse (mas que los
# 6 del juez, porque de verdad tiene que iterar codigo, no solo investigar).
# Con modelos locales mas verbosos investigando (ej. parable/fable en esta
# sesion), 15 se quedaba corto -- la mayoria de las corridas agotaban los
# turnos leyendo/explorando sin llegar nunca a escribir codigo. Si ves ese
# patron ("se agotaron los turnos de herramientas sin terminar" repetido),
# subir esto antes que cualquier otra cosa.
CODING_AGENT_MAX_TURNS=15

# --- Comprobante tecnico automatico (Camino B1, opcional) ---
# Cada vez que el/los agentes terminan de trabajar una historia real (una
# historia individual en --epic modo secuencial via
# _post_child_technical_report, o un ticket normal/epica combinada via
# _deliver), el pipeline le pide al backend LLM que realmente respondio esa
# historia (Ollama u otro segun get_backend_priority()) que redacte un
# "Comprobante de Desarrollo Tecnico" con los datos REALES de ESA historia
# puntual (backend usado, resultado, veredicto del juez, rama) y lo postea
# como comentario extra en ese mismo ticket. El texto lo escribe el
# modelo, no un template Python -- ver tech_doc_agent.py. Best-effort: si
# no hay backend disponible o la generacion falla, no se postea nada (no
# bloquea la corrida). Poner en "false" para desactivarlo (ej. corridas de
# humo repetidas donde no hace falta un comprobante por cada una).
TECH_DOC_ENABLED=true
# Modelo Ollama especifico para este comprobante (opcional) -- si no se
# setea, cae al OLLAMA_MODEL generico.
TECH_DOC_OLLAMA_MODEL=

# --- Orquestacion real (Prefect, opcional) ---
# orchestration.py usa esto para reportar las corridas al servicio
# prefect-server del docker-compose (UI en http://localhost:4200).
PREFECT_API_URL=http://localhost:4200/api

# --- Figma MCP (opcional, para pantallas reales, via interactiva) ---
# No requiere token: el servidor MCP de Figma corre localmente desde
# Figma Desktop (Preferencias > "Enable local MCP Server"), expuesto en
# http://127.0.0.1:3845/sse con el archivo que tengas abierto ahi. Esto es
# para la sesion interactiva de Copilot Chat (ver prompts/build_ui_from_figma.md).

# --- Figma REST API (opcional, para el pipeline automatizado) ---
# Distinto de lo anterior: si el ticket de Jira trae un link real de Figma
# (figma.com/file/... o /design/...?node-id=...) en la descripcion, y esta
# variable esta seteada, figma_client.py le pega a la REST API real de
# Figma (api.figma.com) para traer specs reales (colores/medidas/texto) del
# nodo indicado y sumarlas al prompt compuesto -- sin necesitar Figma
# Desktop abierto. Personal Access Token real: figma.com > Settings > Personal access tokens.
FIGMA_API_TOKEN=

# Nombre exacto de la transicion de workflow a la que mover el ticket si el
# juez marca la corrida como FLAGGED (ajustalo a tu workflow real)
JIRA_BLOCKED_STATUS=Blocked

# Nombre exacto de la transicion de workflow a la que mover el ticket cuando
# el juez marca la corrida como OK (listo para revision humana / merge del
# PR que abrio push_and_open_pr) -- ajustalo a tu workflow real
JIRA_REVIEW_STATUS="Code Review"

# Nombre exacto de la transicion de workflow a la que mover el ticket cuando
# el pipeline detecta que ya esta realmente completado (rama mergeada, o
# ya estaba en este status) -- ajustalo a tu workflow real
JIRA_DONE_STATUS=Done

# Statuses (separados por coma) que el modo --epic considera "terminales" --
# los hijos de una epica en alguno de estos statuses se excluyen ANTES de
# planificar el orden/coordinacion (epic_planner.py), para no gastar un
# turno real de LLM/grafo razonando sobre historias ya cerradas. Default:
# solo JIRA_DONE_STATUS. Si tu workflow tiene otros statuses terminales
# ("Won't Do", "Cancelled", "Duplicate"), agregalos aca.
# JIRA_EPIC_TERMINAL_STATUSES="Done,Won't Do,Cancelled"

# --- Alertas (opcional) ---
# Si seteas esto, el pipeline manda un POST (formato compatible con un
# incoming webhook de Slack: {"text": "..."}) cuando: Falco detecta algo
# durante una corrida, el juez marca FLAGGED, o el testing agent bloquea la
# corrida -- para que alguien reciba una alerta activa en vez de tener que
# leer Jira o los logs JSONL a mano. FALCO_ALERT_WEBHOOK_URL sigue funcionando
# como alias retrocompatible (nombre original, antes de generalizarse).
ALERT_WEBHOOK_URL=
FALCO_ALERT_WEBHOOK_URL=
